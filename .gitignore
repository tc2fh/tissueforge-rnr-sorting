# pixi environment (~1.4G; reproducible from pixi.toml + pixi.lock)
.pixi/

# Nested repositories tracked SEPARATELY -- never vendored into this repo:
#   tissue-forge/    = the engine FORK (its own git + remote tc2fh/tissue-forge)
#   tvm/, 3DVertVor/ = GPL upstream oracles (read-only references; license boundary)
tissue-forge/
tvm/
3DVertVor/

# Derived / build artifacts (regenerable, large): engine CMake build tree + built oracle
tissue-forge_build/
oracle_run/

# Third-party reference PDFs (kept locally; not committed/redistributed)
reference_pdfs/

# Tooling / OS junk
__pycache__/
*.py[cod]
.pytest_cache/
.vscode/
# Local Claude Code state stays ignored, EXCEPT project skills/commands, which are
# version-controlled so they travel with the repo across machines (e.g. /handoff, /resume).
.claude/*
!.claude/skills/
!.claude/commands/
.DS_Store

# Sweep/overnight process logs + intermediate video frames (artifacts, not deliverables;
# the figures/CSVs/GIF they produce ARE tracked under rnr/exports/)
rnr/exports/overnight_logs/
rnr/exports/overnight_run*.log
rnr/exports/sweep_logs/
rnr/exports/sweep_run*.log
rnr/exports/sort_active_frames/
rnr/exports/vertex_motion_frames/
rnr/exports/native_gl_frames/
